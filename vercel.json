{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.ahmadbukhari.com" }],
      "destination": "https://ahmadbukhari.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.ahmadbukhari.com" }],
      "destination": "https://ahmadbukhari.com/:path*",
      "permanent": true
    },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/case-studies", "destination": "/work", "permanent": true },
    { "source": "/case-studies/vendingpreneurs-student-onboarding-automation", "destination": "/work/onboarding", "permanent": true },
    { "source": "/tools/n8n-automation-development", "destination": "/automation-lab", "permanent": true },
    { "source": "/tools/gohighlevel-crm-setup", "destination": "/services/gohighlevel-crm-automation", "permanent": true },
    { "source": "/tools/vapi-voice-ai-integration", "destination": "/services/voice-ai-conversational-intelligence", "permanent": true },
    { "source": "/process", "destination": "https://aixcelsolutions.com/#process", "permanent": true },
    { "source": "/pricing", "destination": "https://aixcelsolutions.com/contact#engagement", "permanent": true },
    { "source": "/free-consultation", "destination": "https://cal.com/ahmad-bukhari/ai-consultancy-call-with-ab", "permanent": true },
    { "source": "/cv", "destination": "/about", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    },
    {
      "source": "/(site.css|experience.js|visual-journey.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    }
  ]
}
